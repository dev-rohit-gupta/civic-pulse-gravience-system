{
  "name": "civic-pulse-gravience-system",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev:server": "npm run dev --workspace=@civic-pulse/server",
    "dev:client": "npm run dev --workspace=@civic-pulse/client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build:client": "npm run build --workspace=@civic-pulse/client",
    "build:server": "npm run build --workspace=@civic-pulse/server",
    "build": "npx turbo run build",
    "build:prod": "NODE_ENV=production npx turbo run build --no-cache",
    "preview": "npm run preview --workspace=@civic-pulse/client",
    "lint": "npx turbo run lint",
    "lint:fix": "npx turbo run lint -- --fix",
    "type-check": "npx turbo run type-check",
    "clean": "npx turbo run clean && rm -rf node_modules/.cache",
    "audit:security": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "test": "npx turbo run test",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dev-rohit-gupta/civic-pulse-gravience-system.git"
  },
  "keywords": [
    "civic",
    "pulse",
    "gravience",
    "system"
  ],
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "minimatch": "^10.2.2",
    "glob": "^11.0.0",
    "rimraf": "^6.0.1"
  },
  "author": "team skoiv",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/dev-rohit-gupta/civic-pulse-gravience-system/issues"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.7.4",
    "typescript": "^5.5.0",
    "@types/node": "^20.14.0"
  },
  "packageManager": "npm@11.10.0",
  "homepage": "https://github.com/dev-rohit-gupta/civic-pulse-gravience-system#readme"
}
