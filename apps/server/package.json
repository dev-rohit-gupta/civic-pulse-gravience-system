    "@google/generative-ai": "^0.15.0",
    "@types/nodemailer": "^7.0.11",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jose": "^6.1.3",
    "mongoose": "^8.5.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
